# Environment for the Pong server unit. Loaded by systemd via
# EnvironmentFile=/etc/pong.env. This file is rewritten by install.sh on
# every deploy; edit the template in deploy/remote/pong.env, not on the server.

# Network bind (loopback only — nginx terminates TLS and proxies).
HOST=127.0.0.1
PORT=8000

# Trust / allowlists.
ALLOWED_HOSTS=peterhoughton.com,www.peterhoughton.com
ALLOWED_ORIGINS=https://www.peterhoughton.com,https://peterhoughton.com

# Forwarded-for handling.
BEHIND_PROXY=true
FORWARDED_ALLOW_IPS=127.0.0.1

# Logging.
LOG_LEVEL=INFO
